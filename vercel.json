{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/auth",
      "destination": "/api/auth/[...path]"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth/[...path]"
    },
    {
      "source": "/api/users",
      "destination": "/api/users/[...path]"
    },
    {
      "source": "/api/users/:path*",
      "destination": "/api/users/[...path]"
    },
    {
      "source": "/api/sensor",
      "destination": "/api/sensor/[...path]"
    },
    {
      "source": "/api/sensor/:path*",
      "destination": "/api/sensor/[...path]"
    },
    {
      "source": "/api/inspection",
      "destination": "/api/inspection/[...path]"
    },
    {
      "source": "/api/inspection/:path*",
      "destination": "/api/inspection/[...path]"
    },
    {
      "source": "/api/harvests",
      "destination": "/api/harvests/[...path]"
    },
    {
      "source": "/api/harvests/:path*",
      "destination": "/api/harvests/[...path]"
    },
    {
      "source": "/:path((?!api).*)",
      "destination": "/index.html"
    }
  ]
}